{
  "version": 2,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/whatsappchat",
      "dest": "/whatsappchat.html"
    },
    {
      "src": "/chat",
      "dest": "/chat.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
